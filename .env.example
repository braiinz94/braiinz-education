# Braiinz Education — Environment variables
# Copy to .env and fill in real values.

# ---------------------------------------------------------------------------
# LLM provider
# ---------------------------------------------------------------------------
# "anthropic" (default) : direct Anthropic API (US region, via DPF + SCC)
# "bedrock"             : AWS Bedrock (recommended for Schrems II compliance —
#                         data stays in EU region set by AWS_REGION)
LLM_PROVIDER=anthropic

# ---------------------------------------------------------------------------
# Direct Anthropic API (used when LLM_PROVIDER=anthropic)
# Get key at https://console.anthropic.com/
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------------------
# AWS Bedrock (used when LLM_PROVIDER=bedrock)
# Recommended region: eu-west-3 (Paris) for French data residency
# AWS credentials via ~/.aws/credentials or AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY
# ---------------------------------------------------------------------------
AWS_REGION=eu-west-3
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...

# ---------------------------------------------------------------------------
# Optional per-tier model override
# On Bedrock, model IDs differ — use inference profile IDs like:
#   eu.anthropic.claude-haiku-4-5-YYYYMMDD-v1:0
#   eu.anthropic.claude-sonnet-4-6-YYYYMMDD-v1:0
#   eu.anthropic.claude-opus-4-6-YYYYMMDD-v1:0
# Leave blank to use defaults from TIER_CONFIG.
# ---------------------------------------------------------------------------
# LLM_MODEL_FAST=
# LLM_MODEL_STANDARD=
# LLM_MODEL_DEEP=

# ---------------------------------------------------------------------------
# Telegram bot
# Create a bot via @BotFather on Telegram
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# ---------------------------------------------------------------------------
# Local data directory (gitignored)
# ---------------------------------------------------------------------------
DATA_DIR=data
